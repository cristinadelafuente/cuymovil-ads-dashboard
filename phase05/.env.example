# ── Fase 0.5 — variables de entorno (SOLO LECTURA) ────────────────────────────
# Copia a .env (o expórtalas en tu shell) y rellena. NO subir credenciales a git.

# Modo de operación del dashboard (déjalo en true durante Fase 0.5/1)
READ_ONLY=true

# Meta Ads
META_ACCESS_TOKEN=
META_APP_ID=1605641477375351
META_APP_SECRET=

# Google Ads (OAuth solo lectura + developer token)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# GA4 (service account con rol Viewer en la propiedad)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/service-account.json

# Microsoft Clarity (token de proyecto, Data Export)
CLARITY_API_TOKEN=
